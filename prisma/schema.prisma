generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  linkedin
  website
}

enum MessageRole {
  user
  assistant
}

model Company {
  id                   String         @id @default(cuid())
  slug                 String         @unique
  name                 String
  sector               String
  description          String         @default("")
  tags                 String[]       @default([])
  logoColor            String?
  aliases              String[]       @default([])
  websiteUrl           String?
  linkedinUrl          String?
  newsFeedUrl          String?
  /// Last successful website strategy: rss | sitemap | article_meta | content_hash | none
  websiteFetchStrategy String?
  websiteContentHash   String?
  lastFetchedAt        DateTime?
  lastError            String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  updates              Update[]
  summaries            DailySummary[]
}

model Update {
  id                   String     @id @default(cuid())
  companyId            String
  company              Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceType           SourceType
  sourceUrl            String
  title                String?
  excerpt              String
  content              String     @default("")
  publishedAt          DateTime
  /// "datetime" | "date" | "unknown" (change-detected)
  publishedAtPrecision String     @default("datetime")
  /// Exact, unmodified scraper payload (JSON string)
  rawSource            String?
  /// sha256(rawSource) for integrity checks / debugging
  rawSourceSha         String?
  dateVerifiedAt       DateTime?
  dateVerifyNote       String?
  fetchStrategy        String?
  fetchedAt            DateTime   @default(now())
  externalId           String

  @@unique([companyId, sourceType, externalId])
  @@unique([companyId, sourceUrl])
  @@index([publishedAt])
  @@index([companyId, publishedAt])
  @@index([sourceUrl])
}

model DailySummary {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  summaryDate    DateTime
  content        String
  citedUpdateIds String   @default("[]")
  createdAt      DateTime @default(now())

  @@unique([companyId, summaryDate])
  @@index([summaryDate])
}

model ChatSession {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String
  citations String      @default("[]")
  createdAt DateTime    @default(now())

  @@index([sessionId, createdAt])
}

model IngestRun {
  id          String    @id @default(cuid())
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  status      String    @default("running")
  summaryJson String    @default("{}")
}
